# =============================================
# REQUIRED - Supabase
# =============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================
# REQUIRED - App URL (your Vercel deployment URL)
# =============================================
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# =============================================
# OPTIONAL - Gmail for sending emails
# Get app password: myaccount.google.com/apppasswords
# =============================================
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# =============================================
# OPTIONAL - Daily.co for real video calls
# Free tier at daily.co — falls back to Jitsi if not set
# =============================================
DAILY_API_KEY=your-daily-api-key
DAILY_DOMAIN=your-subdomain.daily.co

# =============================================
# OPTIONAL - Session duration (default 24h)
# =============================================
SESSION_DURATION_HOURS=24
